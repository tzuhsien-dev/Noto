# Copy to .env and fill in values from your Supabase project
# (Dashboard → Project Settings → API). Only the publishable/anon key
# belongs here — NEVER the service_role key or database password.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Optional: show the sign-up form during initial setup (default: off).
# Disable public sign-ups in the Supabase Dashboard for production.
# VITE_ENABLE_SIGNUP=true
